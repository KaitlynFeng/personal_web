---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { hasOriginal?: boolean };

const { title, description, pubDate, updatedDate, heroImage, tags, hasOriginal } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		{hasOriginal && (
			<div
				id="secret-toggle"
				style="position:fixed;top:0;right:0;width:20px;height:20px;z-index:9999;cursor:default;opacity:0;"
				aria-hidden="true"
			></div>
		)}
		<Header />
		<main class="max-w-3xl mx-auto px-6 py-12">
			<article>
				<!-- Back link -->
				<a href={`${base}/blog`} class="inline-flex items-center gap-1 text-xs text-neutral-500 hover:text-green-400 light:hover:text-green-600 mb-8 transition-colors no-underline hover:no-underline">
					&larr; cd ../blog
				</a>

				<!-- Article Header -->
				<header class="mb-8 pb-6 border-b border-dashed border-neutral-800 light:border-neutral-200">
					{tags && tags.length > 0 && (
						<div class="flex flex-wrap gap-1.5 mb-3">
							{tags.map((tag: string) => (
								<span class="text-[10px] px-1.5 py-0.5 rounded border border-neutral-800 text-neutral-500 light:border-neutral-300">
									{tag}
								</span>
							))}
						</div>
					)}
					<h1 class="text-xl md:text-2xl font-bold text-neutral-100 light:text-neutral-900 leading-tight mb-3">
						{title}
					</h1>
					<div class="flex items-center gap-3 text-xs text-neutral-500">
						<span><FormattedDate date={pubDate} /></span>
						{updatedDate && (
							<span class="italic">
								updated: <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
				</header>

				<!-- Article Content -->
				<div class="prose">
					<slot />
				</div>
			</article>

			<!-- Footer nav -->
			<div class="mt-12 pt-6 border-t border-dashed border-neutral-800 light:border-neutral-200">
				<a href={`${base}/blog`} class="text-xs text-neutral-500 hover:text-green-400 light:hover:text-green-600 transition-colors no-underline hover:no-underline">
					&larr; cd ../blog
				</a>
			</div>
		</main>
		<Footer />
		{hasOriginal && (
			<script>
				const toggle = document.getElementById('secret-toggle');
				const sanitized = document.getElementById('sanitized-content');
				const original = document.getElementById('original-content');
				let showOriginal = false;
				if (toggle && sanitized && original) {
					toggle.addEventListener('click', () => {
						showOriginal = !showOriginal;
						sanitized.style.display = showOriginal ? 'none' : '';
						original.style.display = showOriginal ? '' : 'none';
					});
				}
			</script>
		)}
	</body>
</html>

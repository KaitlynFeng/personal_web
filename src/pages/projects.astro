---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

// Project data - edit this array to add/remove projects
const projects = [
	{
		name: 'my-cli-tool',
		description: 'A command-line tool that does something useful. Built with Python and lots of caffeine.',
		tech: ['Python', 'Click', 'Rich'],
		status: 'wip',      // 'active' | 'wip' | 'archived' | 'planned'
		repo: 'https://github.com',
		docs: null,
		url: null,
	},
	{
		name: 'api-starter',
		description: 'Opinionated FastAPI project template with auth, testing, and Docker baked in.',
		tech: ['FastAPI', 'PostgreSQL', 'Docker'],
		status: 'planned',
		repo: null,
		docs: null,
		url: null,
	},
];

const statusMap: Record<string, { label: string; color: string; lightColor: string }> = {
	active:   { label: 'active',   color: 'text-green-400 border-green-400/30',  lightColor: 'light:text-green-600 light:border-green-600/30' },
	wip:      { label: 'wip',      color: 'text-yellow-400 border-yellow-400/30', lightColor: 'light:text-yellow-600 light:border-yellow-600/30' },
	archived: { label: 'archived', color: 'text-neutral-500 border-neutral-500/30', lightColor: 'light:text-neutral-500 light:border-neutral-400/30' },
	planned:  { label: 'planned',  color: 'text-cyan-400 border-cyan-400/30',    lightColor: 'light:text-cyan-600 light:border-cyan-600/30' },
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`Projects - ${SITE_TITLE}`} description="Things I'm building" />
	</head>
	<body>
		<Header />
		<main class="max-w-3xl mx-auto px-6 py-16">
			<div class="mb-8">
				<div class="text-xs text-neutral-600 light:text-neutral-400 mb-3">
					<span class="text-green-400 light:text-green-600">hayley@dev</span>:<span class="text-cyan-400 light:text-cyan-600">~/projects</span>$ ls -la
				</div>
				<h1 class="text-xl font-bold text-neutral-100 light:text-neutral-900 mb-1">Projects</h1>
				<p class="text-xs text-neutral-500">
					Things I'm building, have built, or plan to build. Each project lives in its own repo.
				</p>
			</div>

			<div class="space-y-1">
				{projects.map((project) => {
					const status = statusMap[project.status] || statusMap.planned;
					return (
						<div class="py-4 border-b border-dashed border-neutral-800 light:border-neutral-200 -mx-3 px-3 rounded hover:bg-neutral-900/50 light:hover:bg-neutral-100/50 transition-colors">
							<div class="flex items-baseline justify-between gap-4 mb-1.5">
								<div class="flex items-baseline gap-2">
									<h3 class="text-sm font-semibold text-neutral-200 light:text-neutral-800">
										{project.name}
									</h3>
									<span class={`text-[10px] px-1.5 py-0.5 rounded border ${status.color} ${status.lightColor}`}>
										{status.label}
									</span>
								</div>
								<div class="flex items-center gap-2 text-xs text-neutral-600 shrink-0">
									{project.repo && (
										<a href={project.repo} target="_blank" class="hover:text-green-400 light:hover:text-green-600 transition-colors no-underline hover:no-underline">
											[repo]
										</a>
									)}
									{project.docs && (
										<a href={project.docs} target="_blank" class="hover:text-green-400 light:hover:text-green-600 transition-colors no-underline hover:no-underline">
											[docs]
										</a>
									)}
									{project.url && (
										<a href={project.url} target="_blank" class="hover:text-green-400 light:hover:text-green-600 transition-colors no-underline hover:no-underline">
											[live]
										</a>
									)}
								</div>
							</div>
							<p class="text-xs text-neutral-500 mb-2">
								{project.description}
							</p>
							<div class="flex flex-wrap gap-1.5">
								{project.tech.map((t: string) => (
									<span class="text-[10px] px-1.5 py-0.5 rounded border border-neutral-800 text-neutral-500 light:border-neutral-300">
										{t}
									</span>
								))}
							</div>
						</div>
					);
				})}
			</div>

			<!-- Empty state hint -->
			<div class="mt-8 py-6 text-center border border-dashed border-neutral-800 light:border-neutral-300 rounded">
				<p class="text-xs text-neutral-600 light:text-neutral-400">
					<span class="text-green-400 light:text-green-600">$</span> More projects coming soon. Stay tuned.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
